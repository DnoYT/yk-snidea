{
  "name": "yk-snidea",
  "displayName": "YK Snidea - AI 提示词 | 数据库 AI 助手",
  "description": "开发上下文整理神器：专为网页版大模型对话设计，一键拼装高质量 Prompt (提示词)，自动读取本地代码与数据库表结构，告别昂贵订阅。",
  "version": "1.0.1",
  "icon": "logo.png",
  "publisher": "Guangxi-Yunke",
  "author": "云天",
  "repository": {
    "type": "git",
    "url": "https://github.com/DnoYT/yk-snidea.git"
  },
  "homepage": "https://github.com/DnoYT/yk-snidea",
  "bugs": {
    "url": "https://github.com/DnoYT/yk-snidea/issues"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Machine Learning",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "AI",
    "Prompt",
    "提示词",
    "数据库",
    "Database",
    "ChatGPT",
    "DeepSeek",
    "Claude",
    "Copilot"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "yk-snidea.initIde",
        "title": "YK Snidea: 初始化 .ide 规范文件夹"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "yk-snidea-container",
          "title": "YK Side",
          "icon": "$(heart)"
        }
      ]
    },
    "views": {
      "yk-snidea-container": [
        {
          "type": "webview",
          "id": "yk-snidea.helloView",
          "name": "YK Snidea"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "yarn run package",
    "compile": "yarn run check-types && yarn run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "dev": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "yarn run check-types && yarn run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "yarn run compile-tests && yarn run compile && yarn run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "build": "vsce package --no-yarn"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "mysql2": "^3.20.0"
  }
}